{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A bike spare part or accessory.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "imageUrl": { "type": "string" },
        "stock": { "type": "integer" },
        "rating": { "type": "number" },
        "reviewCount": { "type": "integer" },
        "tags": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["name", "price", "category", "stock"]
    },
    "Review": {
      "title": "Review",
      "description": "A user review for a product.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "productId": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "productId", "rating", "createdAt"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "paid", "shipped", "delivered", "cancelled"] },
        "trackingId": { "type": "string" },
        "shippingAddress": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "items", "total", "status", "createdAt"]
    },
    "User": {
      "title": "User",
      "description": "User profile data.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "wishlist": { "type": "array", "items": { "type": "string" } },
        "role": { "type": "string", "enum": ["user", "admin"] }
      },
      "required": ["email", "role"]
    },
    "Cart": {
      "title": "Cart",
      "description": "User shopping cart.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "items": { "type": "array" }
      },
      "required": ["userId", "items"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Available products."
    },
    "/products/{productId}/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Reviews for a specific product."
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Orders placed by users."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile info."
    },
    "/users/{userId}/cart/{cartId}": {
      "schema": "Cart",
      "description": "User's active cart."
    }
  }
}
