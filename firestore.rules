rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == 'gostman064@gmail.com'
      );
    }
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    function incoming() {
      return request.resource.data;
    }
    function existing() {
      return resource.data;
    }

    // Product Rules
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();

      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isSignedIn() && 
                      incoming().userId == request.auth.uid && 
                      incoming().rating >= 1 && incoming().rating <= 5;
        allow update, delete: if isOwner(existing().userId);
      }
    }

    // Order Rules
    match /orders/{orderId} {
      allow read: if isOwner(existing().userId) || isAdmin();
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update: if isAdmin(); // Only admin can update status
    }

    // User Rules
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
      
      match /cart/{cartId} {
        allow read, write: if isOwner(userId);
      }
    }
    
    // Admin list
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false;
    }
  }
}
